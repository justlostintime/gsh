' Gambas class file

' Structure definition
Public Struct glob_t   'The structure definition used by the glob system function
  ''          Some size_t functions are implemented as prointer as size_t
  ''          follows the size of the address pointer in most systems
  gl_pathc As Pointer                                      'Count Of paths matched by the pattern. *size_t use ptr as it follows address width and absolute vaue,like size_t
  gl_pathv As Pointer                                      'List Of matched pathnames.  char * * gl_pathv; * /
  gl_offs As Pointer                                          'Slots To reserve In `gl_pathv'.   __size_t gl_offs; */
  gl_flags As Integer                                      'Set To FLAGS, maybe | GLOB_MAGCHAR.  */
  gl_closedir As Pointer                                   'If the GLOB_ALTDIRFUNC flag Is Set, the following functions are used instead Of the normal file access functions.void( * gl_closedir)(void * )
  gl_readdir As Pointer                                    'Struct dirent * ( * gl_readdir)(void * );
  gl_opendir As Pointer                                    'void * ( * gl_opendir)(const char * );
  gl_lstat As Pointer                                      'Int( * gl_lstat)(const char * __restrict, struct stat * __restrict);
  gl_stat As Pointer                                       'Int( * gl_stat)(const char * __restrict, struct stat * __restrict);
End Struct

' Constants used

Public Const Glob_ERR As Integer = &h0001              ' Return On Read errors. * /
Public Const Glob_MARK As Integer = &h0002              ' Append a slash To Each name. * /
Public Const Glob_NOSORT As Integer = &h0004              ' Don 't sort the names.  */
Public Const Glob_DOOFFS As Integer = &h0008             ' Insert PGLOB - > gl_offs NULLs. * /
Public Const Glob_NOCHECK As Integer = &h0010             ' If nothing matches, Return the pattern. * /
Public Const Glob_APPEND As Integer = &h0020              ' Append To results Of a previous call. * /
Public Const Glob_NOESCAPE As Integer = &h0040              ' Backslashes don 't quote metacharacters.  */
Public Const Glob_PERIOD As Integer = &h0080              ' Leading `.' can be matched by metachars.  */
Public Const Glob_MAGCHAR As Integer = &h0100             ' Set In gl_flags If any metachars seen. * /
Public Const Glob_ALTDIRFUNC As Integer = &h0200              ' Use gl_opendir et al functions. * /
Public Const Glob_BRACE As Integer = &h0400              ' Expand "{a,b}" To "a" "b". * /
Public Const Glob_NOMAGIC As Integer = &h0800              ' If no magic chars, Return the pattern. * /
Public Const Glob_TILDE As Integer = &h1000              ' Expand ~user and ~ to home directories. */
Public Const Glob_ONLYDIR As Integer = &h2000           ' Match only directories. * /
Public Const Glob_TILDE_CHECK As Integer = &h4000
